# backup-family 환경변수 예시
# 이 파일을 복사하여 .env.local 을 생성하고 실제 값을 채워주세요.
# cp .env.example .env.local

# Supabase — https://supabase.com/dashboard/project/<project>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# 카카오 JS SDK — https://developers.kakao.com/console/app/<app-id>/config
NEXT_PUBLIC_KAKAO_APP_KEY=your-kakao-js-app-key

# 보호자 검색 페이지 액세스 코드 (서버 전용 — NEXT_PUBLIC_ 붙이지 마세요)
# 운영팀이 보호자에게 발급하는 코드입니다. 임의의 문자열로 설정하세요.
SEARCH_ACCESS_CODE=your-secret-access-code
