# backup-family 환경변수 예시
# 이 파일을 복사하여 .env.local 을 생성하고 실제 값을 채워주세요.
# cp .env.example .env.local

# Supabase — https://supabase.com/dashboard/project/<project>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# 카카오 JS SDK — https://developers.kakao.com/console/app/<app-id>/config
NEXT_PUBLIC_KAKAO_APP_KEY=your-kakao-js-app-key
